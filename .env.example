# ====================================================
# Canvas LMS - Environment Variables
# Copy this file to .env and fill in the values.
# ====================================================

# --- Database ---
DATABASE_URL="postgresql://user:password@host:5432/canvas_lms"
DATABASE_POOL_SIZE="10"

# --- Authentication ---
# Generate a secure random string (at least 32 characters)
JWT_SECRET="your_super_secret_jwt_key_at_least_32_characters_long"

# --- AI (Google Gemini) ---
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# --- Email (Resend) ---
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# IMPORTANT: You must verify your domain in Resend dashboard
# For development with FREE tier: Use the email you registered with Resend
# Example: If you registered with nguyenxuanmanh918@gmail.com, only that email will receive OTP
# For production: Verify your domain and use: noreply@yourdomain.com
RESEND_FROM_EMAIL="onboarding@resend.dev"

# RESEND VERIFIED EMAIL (for testing with free tier)
# This is the email address you used to register your Resend account
# Only this email can receive emails with free tier
RESEND_VERIFIED_EMAIL="nguyenxuanmanh918@gmail.com"

# --- App Configuration ---
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# --- Logging ---
LOG_LEVEL="info"

# --- Rate Limiting ---
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="900"

# --- Optional: Security Headers ---
# CORS_ORIGIN="http://localhost:3000"
# SECURE_COOKIES="false"

# --- RAG System (Retrieval-Augmented Generation) ---
# Pinecone Vector Database
PINECONE_API_KEY="your_pinecone_api_key_here"
PINECONE_ENVIRONMENT="us-west1-gcp"
PINECONE_INDEX_NAME="canvas-lms-rag"

# Google Embeddings (can reuse GEMINI_API_KEY)
GOOGLE_EMBEDDING_API_KEY="YOUR_GEMINI_API_KEY"

# Python RAG API
PYTHON_API_URL="http://localhost:8000"
RAG_API_KEY="your_rag_api_key_here"

