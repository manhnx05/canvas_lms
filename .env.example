# ====================================================
# Canvas LMS - Environment Variables
# Copy this file to .env and fill in the values.
# ====================================================

# --- Database ---
DATABASE_URL="postgresql://user:password@host:5432/canvas_lms"
DATABASE_POOL_SIZE="10"

# --- Authentication ---
# Generate a secure random string (at least 32 characters)
JWT_SECRET="your_super_secret_jwt_key_at_least_32_characters_long"

# --- AI (Google Gemini) ---
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# --- Email (Resend) ---
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# IMPORTANT: You must verify your domain in Resend dashboard
# For development, you can use: onboarding@resend.dev
# For production, use your verified domain: noreply@yourdomain.com
RESEND_FROM_EMAIL="onboarding@resend.dev"

# --- App Configuration ---
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# --- Logging ---
LOG_LEVEL="info"

# --- Rate Limiting ---
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="900"

# --- Optional: Security Headers ---
# CORS_ORIGIN="http://localhost:3000"
# SECURE_COOKIES="false"
