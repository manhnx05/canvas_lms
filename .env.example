# ====================================================
# Canvas LMS - Environment Variables
# Copy this file to .env and fill in the values.
# ====================================================

# --- Database ---
DATABASE_URL="postgresql://user:password@host:5432/canvas_lms"

# --- Authentication ---
JWT_SECRET="your_super_secret_jwt_key"

# --- AI (Google Gemini) ---
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# --- Email (Resend) ---
RESEND_API_KEY="YOUR_RESEND_API_KEY"

# --- App URL (Production) ---
# Set this to your Vercel deployment URL for correct email notification links.
# Example: https://canvas-lms.vercel.app
FRONTEND_URL="http://localhost:3000"
