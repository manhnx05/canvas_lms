generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  otp       String?
  role      String   // 'student' or 'teacher'
  avatar    String?
  stars     Int?     @default(0)
  className String?

  conversations Participant[]
  messages      Message[]
  enrollments   Enrollment[]
  notifications Notification[]
  submissions   Submission[]
}

model Course {
  id            String   @id @default(uuid())
  title         String
  color         String
  icon          String
  teacher       String
  studentsCount Int      @default(0)
  progress      Int?
  description   String?

  assignments   Assignment[]
  modules       CourseModule[]
  announcements Announcement[]
  enrollments   Enrollment[]
  conversations Conversation[]
  exams         Exam[]
}

model CourseModule {
  id        String       @id @default(uuid())
  title     String
  order     Int          @default(0)
  courseId  String
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  items     ModuleItem[]
}

model ModuleItem {
  id        String       @id @default(uuid())
  title     String
  type      String       // 'file' | 'link' | 'page' | 'elearning'
  url       String?
  content   String?
  order     Int          @default(0)
  moduleId  String
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  date      String
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  courseId    String
  courseName  String
  dueDate     String
  starsReward Int      @default(0)
  status      String   // 'pending' | 'submitted' | 'graded'
  type        String   // 'quiz' | 'drawing' | 'reading' | 'writing'
  description String?
  questions   Json?    // Dành cho tự động ra đề

  course      Course       @relation(fields: [courseId], references: [id])
  submissions Submission[]
}

model Submission {
  id           String     @id @default(uuid())
  assignmentId String
  userId       String
  answers      Json?
  status       String     @default("submitted") // 'submitted' | 'graded'
  score        Int?
  aiFeedback   String?
  timestamp    String?

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
}

model Reward {
  id          String   @id @default(uuid())
  title       String
  description String
  icon        String
  color       String
  dateEarned  String
}

model Conversation {
  id          String   @id @default(uuid())
  subject     String?
  courseId    String?
  course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  unreadCount Int      @default(0)
  
  participants Participant[]
  messages     Message[]
}

model Participant {
  id             String       @id @default(uuid())
  userId         String
  conversationId String

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@unique([userId, conversationId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  attachments    Json?
  timestamp      String
  isRead         Boolean      @default(false)

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  date      String
  isRead    Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exam {
  id          String     @id @default(uuid())
  title       String
  subject     String     // 'math' | 'physics' | 'chemistry' | 'biology' | 'literature' | 'history' | 'geography'
  grade       String     // '1' | '2' | '3' | '4' | '5'
  duration    Int        // phút
  totalScore  Int        @default(10)
  standard    String     @default("cv7991") // chuẩn Công văn 7991
  difficulty  String     @default("medium")  // 'easy' | 'medium' | 'hard'
  questions   Json       // mảng ExamQuestion[]
  courseId    String?
  createdBy   String     // userId giáo viên
  createdAt   DateTime   @default(now())
  status      String     @default("draft") // 'draft' | 'published'

  course      Course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)
  sourceFiles ExamFile[]
}

model ExamFile {
  id         String   @id @default(uuid())
  examId     String?
  name       String
  size       Int      @default(0)
  type       String   // 'textbook' | 'reference'
  url        String   // đường dẫn file trên server
  uploadedAt DateTime @default(now())

  exam       Exam?    @relation(fields: [examId], references: [id], onDelete: SetNull)
}
